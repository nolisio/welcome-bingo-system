# docker compose 用の共通設定

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=bingo

DB_PORT=5432
SERVER_PORT=4000
CLIENT_PORT=3000

# ブラウザから表示するフロントエンド URL
CLIENT_URL=https://bingo.example.com

# クライアントが接続する API / Socket.IO の公開 URL
# Next.js はビルド時にもこの値を使うため、docker compose build 前に必ず設定する
NEXT_PUBLIC_SERVER_URL=https://api.bingo.example.com

# 必ず安全なランダム値に変更する
ADMIN_SECRET=replace-with-a-strong-random-secret
